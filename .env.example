# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env sur GitHub

# URL PostgreSQL — fournie automatiquement par Railway
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Clé secrète JWT — générer une valeur aléatoire forte en production
# Exemple : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changez-cette-valeur-en-production

# Environnement
NODE_ENV=production

# URL publique de l'app (pour les liens dans les emails)
APP_URL=https://votre-app.up.railway.app

# Brevo — envoi d'emails transactionnels (300 emails/jour gratuits)
# 1. Créer un compte sur brevo.com
# 2. Récupérer la clé API : Paramètres → SMTP & API → API Keys
# 3. Vérifier l'email expéditeur : Paramètres → Expéditeurs → Ajouter un expéditeur
BREVO_API_KEY=votre-cle-api-brevo
BREVO_FROM=votre-email-verifie@gmail.com
