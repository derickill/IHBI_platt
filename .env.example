# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env sur GitHub

# URL PostgreSQL — fournie automatiquement par Railway
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Clé secrète JWT — générer une valeur aléatoire forte en production
# Exemple : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changez-cette-valeur-en-production

# Environnement
NODE_ENV=production

# URL publique de l'app (pour les liens dans les emails)
APP_URL=https://votre-app.up.railway.app

# SMTP — configuration email (ex: Gmail, SendGrid, Brevo…)
# Si non configuré, les comptes sont créés mais les emails ne sont pas envoyés
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-application
SMTP_FROM="IHBI Platform" <votre-email@gmail.com>
