# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env sur GitHub

# URL PostgreSQL — fournie automatiquement par Railway
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Clé secrète JWT — générer une valeur aléatoire forte en production
# Exemple : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changez-cette-valeur-en-production

# Environnement
NODE_ENV=production
